# Copy this file to android/key.properties and fill in your keystore details.
# key.properties is in .gitignore — never commit it.
#
# To generate a keystore:
#   keytool -genkey -v -keystore fitforge-release.jks -alias fitforge -keyalg RSA -keysize 2048 -validity 10000
#
storePassword=YOUR_KEYSTORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=fitforge
storeFile=../fitforge-release.jks
